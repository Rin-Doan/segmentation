	doi = {10.1109/CINE63708.2024.10880887},
	abstract = {The aim of this study is to develop an automatic system that uses deep learning techniques to detect cervical spine fractures from medical images. Using a {DICOM} (Digital imaging and communications in medicine) images of cervical spine, the system can identify a fracture and specify which vertebrae has a fracture. This process involves first processing provided {DICOM} images, then applying data augmentation techniques including metadata information, finally designing neural network architecture for feature extraction. We use a method called transfer learning, utilizing a pre-trained model like {EfficientNet}, which is used for feature extraction, while optimizing network parameters using {AdanW} optimizer and {CosineAnnealingWarmup} learning rate scheduler. The results demonstrate the successful training of neural network models to identify fracture and that fractured vertebrae, with commendable performance and accuracy level noted during evaluation on validation data. This study has important implications for medical imaging and healthcare industries, since automated fracture detection can increase diagnostic efficiency and accuracy. Moreover, such a system would provide good support to healthcare professionals, specifically radiologists, to identify cervical spine fracture easily.},
	eventtitle = {2024 6th International Conference on Computational Intelligence and Networks ({CINE})},
	pages = {1--6},
	booktitle = {2024 6th International Conference on Computational Intelligence and Networks ({CINE})},
	publisher = {{IEEE}},
	author = {Sidpara, Pragati and Agarwal, Anshul and Swain, Debabrata and Gupta, Rajeev Kumar and Bhilare, Amol and Upkare, Makarand},
	urldate = {2026-01-05},
	date = {2024-12-19},
	langid = {english},
	file = {PDF:/Users/tuongdoanvanngoc/Zotero/storage/DKIHZPAT/Sidpara et al. - 2024 - EfficientNet Convolutional Neural Network for Automated Cervical Spine Fracture Identification.pdf:application/pdf},
}

@article{sutradhar_cervical_2025,
	title = {Cervical spine fracture detection utilizing {YOLOv}8 and deep attention-based vertebrae classification ensuring {XAI}},
	volume = {101},
	issn = {17468094},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1746809424012862},
	doi = {10.1016/j.bspc.2024.107228},
	abstract = {Fractures, especially in the cervical spine, pose significant challenges for diagnosis and treatment. As the incidence of these injuries rises and traditional diagnostic methods have limitations, there is an urgent need for more efficient and accurate detection techniques. This study addresses these challenges by proposing a comprehensive approach to automate fracture detection and classification of cervical spine injuries from {CT} scans. We have combined object detection models and a novel attention mechanism-based Convolutional Neural Network ({CNN}) titled ({VertNet}-10) to detect cervical spinal fractures and classify vertebrae from axial plane {CT} images. Our methodology involves refining the {YOLOv}8 object detection model and proposing a deep {CNN} model with attention blocks. Our modified {YOLOv}8 achieved a Mean Average Precision ({mAP}) of 93 \% in fracture detection, outperforming existing models. The {CNN} model achieved an accuracy of 99.55 \% in classifying cervical vertebrae, with 100 \% accuracy for some vertebrae. Furthermore, we successfully generated activation maps to explain the model’s classification process, enhancing model explainability. By combining these two modules, our proposed approach offers a promising solution for automating fracture detection and cervical vertebrae classification. Integrating advanced imaging algorithms and attention mechanisms significantly improves diagnostic precision and efficiency. This study emphasizes the potential of {AI}-driven systems in augmenting radiological diagnosis and ultimately improving patient care in cervical spine injuries.},
	pages = {107228},
	journaltitle = {Biomedical Signal Processing and Control},
	shortjournal = {Biomedical Signal Processing and Control},
	author = {Sutradhar, Debopom and Fahad, Nur Mohammad and Khan Raiaan, Mohaimenul Azam and Jonkman, Mirjam and Azam, Sami},
	urldate = {2026-01-05},
	date = {2025-03},
	langid = {english},
	file = {PDF:/Users/tuongdoanvanngoc/Zotero/storage/LJ75QQPZ/Sutradhar et al. - 2025 - Cervical spine fracture detection utilizing YOLOv8 and deep attention-based vertebrae classification.pdf:application/pdf},
}

@inproceedings{yaseen_deep_2024,
	location = {Pyeong Chang, Korea, Republic of},
	title = {Deep Learning Based Cervical Spine Bones Detection: A Case Study Using {YOLO}},
	rights = {https://doi.org/10.15223/policy-029},
	isbn = {979-11-88428-12-0},
	url = {https://ieeexplore.ieee.org/document/10472013/},
	doi = {10.23919/ICACT60172.2024.10472013},
	shorttitle = {Deep Learning Based Cervical Spine Bones Detection},
	abstract = {Cervical spine bones detection plays a crucial role in various medical applications, such as diagnosis, surgical planning, and treatment assessment. Traditional methods for cervical spine bones detection often rely on manual identification and segmentation, which are time-consuming and prone to errors. In recent years, deep learning approaches have shown great potential in automating the detection process and achieving high accuracy. In this research paper, we propose a deep learning-based approach for detecting cervical spine bones. Our suggested approach employs the {YOLOv}5 architecture, a cutting-edge object identification system renowned for its effectiveness and precision. The model is trained to recognize and locate bones structures using computed tomography ({CT}) scans image of the cervical spine as inputs. We conduct extensive evaluations using the trained models on the cervical spine dataset. The mean average precision ({mAP}) scores achieved by our model are 93\% at threshold ({mAP}\_0.5) and 83\% at thresholds ranging from ({mAP}\_0.5:0.95), which demonstrate the effectiveness of our approach in accurately detecting and localizing cervical spine bones. Our deep learning-based method for detecting cervical spine bones with high {mAP} scores presented in this research paper has significant implications for medical applications. With accurate and reliable bones detection, medical professionals can enhance diagnosis, surgical planning, and treatment assessment processes. The achieved {mAP} scores showcase the performance and potential of our proposed method, contributing to the advancement of bone detection techniques in cervical spine imaging and facilitating collaboration between the medical imaging and deep learning communities.},
	eventtitle = {2024 26th International Conference on Advanced Communications Technology ({ICACT})},
	pages = {01--05},
	booktitle = {2024 26th International Conference on Advanced Communications Technology ({ICACT})},
	publisher = {{IEEE}},
	author = {Yaseen, Muhammad and Ali, Maisam and Ali, Sikander and Hussain, Ali and Athar, Ali and Kim, Hee-Cheol},
	urldate = {2026-01-05},
	date = {2024-02-04},
	langid = {english},
	file = {PDF:/Users/tuongdoanvanngoc/Zotero/storage/YTIVYLKU/Yaseen et al. - 2024 - Deep Learning Based Cervical Spine Bones Detection A Case Study Using YOLO.pdf:application/pdf},
}

