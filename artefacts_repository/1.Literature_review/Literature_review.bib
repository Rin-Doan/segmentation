@article{noauthor_automatic_nodate,
	title = {Automatic medical image segmentation with u-net: A deep learning approach (review)},
	issn = {2707661X, 27076628},
	abstract = {Since U-Net uses an encoder-decoder structure and has effectively employed skip connections, it has established itself as a baseline in medical image segmentation. Since its invention, it has spawned an enormous amount of U-Net variants to address various issues such as arcane contextual representation, class imbalance, and generalisation across a variety of imaging modalities. The current review presents a chronological summary of the main architecture improvements, i.e. Residual U-Net, Attention U-Net, U-Net+, and {nnU}-Net, highlighting the structural novelty, the rationale each of these versions represented, and their applicability. Additionally, commonly used biomedical datasets are explored with regard to segmentation work and related performance results. The review will inform researchers to choose the most appropriate U-Net-based model based on the type of clinical imaging problem.},
	journaltitle = {International Journal of Communication and Information Technology},
	shortjournal = {Int. J. Commun. Inf. Technol.},
	langid = {english},
	file = {PDF:/Users/tuongdoanvanngoc/Zotero/storage/QQU4WFEM/[No title found].pdf:application/pdf},
}

